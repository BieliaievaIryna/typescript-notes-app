{
  "compilerOptions": {
    "module": "NodeNext", 
    "target": "esnext",                                  
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,    
    "skipLibCheck": true,
    "lib": ["ES2023"],
    "rootDir": "src",
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src"]                             
}
